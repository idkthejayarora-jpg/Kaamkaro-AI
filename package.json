{
  "name": "kaamkaro-ai",
  "version": "1.0.0",
  "description": "Kaamkaro AI — Staff Performance Intelligence Platform",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"server,client\" -c \"yellow,cyan\" \"npm run server\" \"npm run client\"",
    "server": "cd server && node index.js",
    "server:dev": "cd server && npx nodemon index.js",
    "client": "cd client && npm run dev",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install",
    "build": "cd client && npm run build",
    "start": "NODE_ENV=production cd server && node index.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
