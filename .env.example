# Kaamkaro AI — Environment Variables
# Copy this file to server/.env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# JWT Secret — change this to a long random string in production
JWT_SECRET=kaamkaro-kamal-secret-change-in-production

# Anthropic API Key — required for Kamal AI and PDF scanning
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
